generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String       @id @default(cuid())
  name               String
  email              String       @unique
  passwordHash       String
  plan               String       @default("FREE")
  generationCount    Int          @default(0)
  lastGenerationDate DateTime?
  fridgeItems        FridgeItem[]
  recipes            Recipe[]
  menuPlans          MenuPlan[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model FridgeItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  category   String
  status     String
  statusType String
  freshness  Int
  quantity   String
  expiryDays Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Recipe {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String
  time           String
  servings       String
  difficulty     String
  difficultyType String
  image          String
  instructions   String   @default("")
  detailedInstructions String @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MenuPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       String
  meals     Meal[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Meal {
  id           String           @id @default(cuid())
  menuPlanId   String
  menuPlan     MenuPlan         @relation(fields: [menuPlanId], references: [id], onDelete: Cascade)
  type         String
  name         String
  recipeContent String?
  ingredients  MealIngredient[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model MealIngredient {
  id        String   @id @default(cuid())
  mealId    String
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
